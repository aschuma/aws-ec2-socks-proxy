# Load optional local overrides.
dotenv_if_exists .env
dotenv_if_exists .env.local

# Re-evaluate when dependency definitions change.
# watch_file pyproject.toml
# watch_file uv.lock

if ! command -v uv >/dev/null 2>&1; then
  echo "uv is required. Install: https://docs.astral.sh/uv/"
  return 1
fi

# Create the uv-managed virtualenv on first load.
if [ ! -x .venv/bin/python ]; then
  echo "Creating project virtualenv with uv sync..."
  uv sync
fi

export VIRTUAL_ENV="$PWD/.venv"
PATH_add "$VIRTUAL_ENV/bin"

# Ensure AWS shared config and credentials are both loaded by SDKs/CLI.
export AWS_SDK_LOAD_CONFIG=1